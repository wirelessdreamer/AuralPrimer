{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://auralprimer.dev/schemas/songpack/charts/chart.schema.json",
  "title": "charts/*.json (minimal)",
  "type": "object",
  "additionalProperties": true,
  "required": ["chart_version", "mode", "difficulty", "targets"],
  "properties": {
    "chart_version": { "type": "string" },
    "mode": { "type": "string" },
    "difficulty": { "type": "string" },
    "targets": { "type": "array" }
  }
}
