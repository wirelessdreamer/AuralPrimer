{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://auralprimer.dev/schemas/songpack/features/sections.schema.json",
  "title": "features/sections.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["sections_version", "sections"],
  "properties": {
    "sections_version": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["t0", "t1", "label"],
        "properties": {
          "t0": { "type": "number", "minimum": 0 },
          "t1": { "type": "number", "minimum": 0 },
          "label": { "type": "string" }
        }
      }
    }
  }
}
