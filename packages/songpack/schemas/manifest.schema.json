{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://auralprimer.dev/schemas/songpack/manifest.schema.json",
  "title": "SongPack manifest.json",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "song_id", "title", "artist", "duration_sec"],
  "properties": {
    "schema_version": { "type": "string" },
    "song_id": { "type": "string" },
    "title": { "type": "string" },
    "artist": { "type": "string" },
    "duration_sec": { "type": "number", "minimum": 0 }
  }
}
