{
  "name": "auralprimer",
  "private": true,
  "packageManager": "npm@10",
  "workspaces": [
    "apps/*",
    "packages/*",
    "visualizers/*"
  ],
  "scripts": {
    "lint": "echo 'lint not configured yet'",
    "test": "vitest run",
    "test:coverage:playback": "vitest run apps/game/tests/nativeAudioTimebase.test.ts apps/desktop/tests/nativeAudioTimebase.test.ts --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.include=apps/game/src/nativeAudioTimebase.ts --coverage.include=apps/desktop/src/nativeAudioTimebase.ts --coverage.thresholds.lines=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100 --coverage.thresholds.branches=100",
    "test:coverage": "vitest run --coverage",
    "game:dev": "npm -w @auralprimer/game run tauri:dev",
    "game:build": "npm -w @auralprimer/game run tauri:build",
    "game:build:frontend": "npm -w @auralprimer/game run build",
    "studio:dev": "npm -w @auralprimer/studio run tauri:dev",
    "studio:dev:asio": "npm -w @auralprimer/studio run tauri:dev:asio",
    "studio:build": "npm -w @auralprimer/studio run tauri:build",
    "studio:build:asio": "npm -w @auralprimer/studio run tauri:build:asio",
    "studio:build:frontend": "npm -w @auralprimer/studio run build",
    "desktop:dev": "npm run studio:dev",
    "desktop:dev:asio": "npm run studio:dev:asio",
    "desktop:build": "npm run studio:build",
    "desktop:build:asio": "npm run studio:build:asio",
    "desktop:build:frontend": "npm run studio:build:frontend",
    "portable:sidecar": "powershell -NoProfile -ExecutionPolicy Bypass -File ./build_sidecar.ps1",
    "portable:build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./create_portable.ps1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.16",
    "@types/node": "^25.0.3",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/cli": "^2.9.6",
    "ajv": "^8.17.1",
    "fflate": "^0.8.2"
  }
}
