{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AuralPrimer",
  "version": "0.0.0",
  "identifier": "dev.auralprimer.game",
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"]
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AuralPrimer",
        "width": 1024,
        "height": 768
      }
    ]
  }
}
