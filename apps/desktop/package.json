{
  "name": "@auralprimer/studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "tauri:sidecar": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../build_sidecar.ps1 -RepoRoot ../.. -SyncTauriBinaries -TauriAppRoots apps/desktop/src-tauri apps/game/src-tauri",
    "tauri:dev": "npm run tauri:sidecar && tauri dev",
    "tauri:dev:asio": "npm run tauri:sidecar && tauri dev --features asio",
    "tauri:build": "npm run tauri:sidecar && tauri build",
    "tauri:build:asio": "npm run tauri:sidecar && tauri build --features asio"
  },
  "dependencies": {
    "@auralprimer/viz-beats": "*",
    "@auralprimer/viz-drum-highway": "*",
    "@auralprimer/viz-fretboard": "*",
    "@auralprimer/viz-lyrics": "*",
    "@auralprimer/viz-nashville": "*",
    "@auralprimer/viz-sdk": "*",
    "@tauri-apps/plugin-dialog": "^2.4.2"
  }
}
